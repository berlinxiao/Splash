<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center|top"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/sheet_lottie_cool"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/space_6"
        app:lottie_rawRes="@raw/lottie_cool"
        app:lottie_autoPlay="true"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sheet_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="@dimen/space_6"
        android:paddingEnd="@dimen/space_6"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        tools:text="142 MB"/>
    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="@dimen/space_6"
        android:paddingEnd="@dimen/space_6"
        android:layout_marginBottom="@dimen/space_6"
        android:text="@string/set_clear_confirm"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="15sp" />



    <com.google.android.material.button.MaterialButton
        android:id="@+id/sheet_confirm_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_4"
        android:layout_marginTop="@dimen/space_6"
        android:layout_marginStart="@dimen/space_6"
        android:layout_marginEnd="@dimen/space_6"
        android:text="@string/set_confirm"
        app:cornerRadius="@dimen/space_6"/>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.App.Button.Secondary"
        android:id="@+id/sheet_cancel_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_6"
        android:layout_marginStart="@dimen/space_6"
        android:layout_marginEnd="@dimen/space_6"
        android:text="@string/set_cancel"
        app:cornerRadius="@dimen/space_6"/>

</LinearLayout>