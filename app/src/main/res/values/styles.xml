<resources>
    <!--show_photo内的exif信息调用-->
    <style name="CameraRow"> <!--包裹-->
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">8dp</item>
    </style>
    <style name="CameraLabel"> <!--大标题-->
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:layout_alignParentStart">true</item>
    </style>
    <style name="CameraValue"> <!--小标题-->
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:layout_alignParentEnd">true</item>
    </style>
    <style name="CameraSeparator"> <!--分割线-->
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">?attr/colorOutlineVariant</item>
    </style>

    <!--fragment_set内用 <item name="cardCornerRadius">@dimen/space_5</item>-->
    <style name="SetCardView" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">@dimen/space_2</item>
        <item name="cardElevation">@dimen/space_1</item>
    </style>
    <style name="SetTextTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/space_5</item>
        <item name="android:layout_marginStart">@dimen/space_3</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="SetTextContent">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">@dimen/space_2</item>
        <item name="android:layout_alignParentEnd">true</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
    <style name="SetTextDescription">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">@dimen/space_2</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">16sp</item>
    </style>
    <style name="SetCardViewSelect">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/space_16</item>
        <item name="android:paddingStart">@dimen/space_5</item>
        <item name="android:paddingEnd">@dimen/space_5</item>
        <item name="android:background">?attr/colorOnPrimary</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="PopupFadeAnim" parent="@android:style/Animation.Dialog">
        <item name="android:windowEnterAnimation">@anim/popup_enter</item>
        <item name="android:windowExitAnimation">@anim/popup_exit</item>
    </style>


</resources>
